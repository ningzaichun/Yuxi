# Yuxi host-native development configuration for infrastructure server 192.168.1.24.
#
# Usage:
# 1. Copy or merge this file into the repository root .env.
# 2. Replace every <...> placeholder locally.
# 3. Never commit the resulting root .env or any real credential.
# 4. Percent-encode special characters in the POSTGRES_URL password.

YUXI_ENV=development
LITE_MODE=false
JWT_SECRET_KEY=<GENERATE_A_RANDOM_LONG_SECRET>
YUXI_INSTANCE_ID=yuxi-dev-192-168-1-24
YUXI_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Remote infrastructure: 192.168.1.24
# PostgreSQL defaults follow deploy/split/.env.infra.template:
# user=postgres, database=yuxi, port=5432.
POSTGRES_URL=postgresql+asyncpg://postgres:<URL_ENCODED_POSTGRES_PASSWORD>@192.168.1.24:5432/yuxi

# The original docker-compose.prod.yml Redis service does not enable authentication.
REDIS_URL=redis://192.168.1.24:6379/0

NEO4J_URI=bolt://192.168.1.24:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=<NEO4J_PASSWORD>

MILVUS_URI=http://192.168.1.24:19530
MILVUS_DB=yuxi
MILVUS_TOKEN=

MINIO_URI=http://192.168.1.24:9000
MINIO_PUBLIC_URI=http://192.168.1.24:9000
MINIO_ACCESS_KEY=<MINIO_ACCESS_KEY>
MINIO_SECRET_KEY=<MINIO_SECRET_KEY>

# Model and external tool credentials.
SILICONFLOW_API_KEY=
TAVILY_API_KEY=
# YUXI_SUPER_ADMIN_NAME=
# YUXI_SUPER_ADMIN_PASSWORD=

# OCR/document parser services are intentionally not configured.
# Do not select MinerU, PaddleX or PaddleOCR parsers in this environment.
MINERU_API_URI=
PADDLEX_URI=
PADDLEOCR_API_TOKEN=
PADDLEOCR_API_URL=

# Host-native application ports.
HOST_DEV_API_HOST=127.0.0.1
HOST_DEV_API_PORT=5050
HOST_DEV_WEB_HOST=127.0.0.1
HOST_DEV_WEB_PORT=5173
HOST_DEV_SANDBOX_HOST=127.0.0.1
HOST_DEV_SANDBOX_PORT=8002
VITE_API_URL=http://127.0.0.1:5050

# API/Worker connect to the local host-process Sandbox Provisioner.
SANDBOX_PROVIDER=provisioner
SANDBOX_PROVISIONER_URL=http://127.0.0.1:8002
SANDBOX_VIRTUAL_PATH_PREFIX=/home/gem/user-data
SANDBOX_EXEC_TIMEOUT_SECONDS=180
SANDBOX_MAX_OUTPUT_BYTES=262144

# The Provisioner runs as a host process; actual Sandbox runtimes use local Docker.
PROVISIONER_BACKEND=docker
SANDBOX_IMAGE=enterprise-public-cn-beijing.cr.volces.com/vefaas-public/all-in-one-sandbox:latest
SANDBOX_CONTAINER_PORT=8080
DOCKER_THREADS_HOST_PATH=
DOCKER_SANDBOX_PREFIX=yuxi-host-sandbox
DOCKER_SANDBOX_HOST=127.0.0.1
SANDBOX_HEALTH_TIMEOUT_SECONDS=300
SANDBOX_IDLE_TIMEOUT_SECONDS=120
SANDBOX_IDLE_CHECK_INTERVAL_SECONDS=10

# Bypass HTTP proxies for the private infrastructure server.
NO_PROXY=localhost,127.0.0.1,192.168.1.24,api.siliconflow.cn
