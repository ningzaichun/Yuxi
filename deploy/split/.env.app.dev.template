# Copy this file to deploy/split/.env.app.dev.
# Values in this file are loaded by the containers and used for Compose interpolation.

APP_BIND_HOST=127.0.0.1
API_PORT=5050
WEB_PORT=5173
SANDBOX_PROVISIONER_PORT=8002
LITE_MODE=false

# Use the infrastructure server's private IP/domain, never localhost from a container.
# If the services run on this Docker Desktop host, host.docker.internal is valid.
# Percent-encode special characters in URL passwords.
POSTGRES_URL=
REDIS_URL=

NEO4J_URI=
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=

MILVUS_URI=
MILVUS_DB=yuxi
MILVUS_TOKEN=

MINIO_URI=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
# Host name or IP only. The current code always generates http://HOST_IP:9000 links.
HOST_IP=

# Generate independent random values for each environment.
JWT_SECRET_KEY=
YUXI_INSTANCE_ID=
YUXI_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Model and external tool credentials used by the existing application.
SILICONFLOW_API_KEY=
TAVILY_API_KEY=
# YUXI_SUPER_ADMIN_NAME=
# YUXI_SUPER_ADMIN_PASSWORD=

# Optional remote document parser services. Leave empty if unused.
MINERU_API_URI=
PADDLEX_URI=
PADDLEOCR_API_TOKEN=
PADDLEOCR_API_URL=https://paddleocr.aistudio-app.com/api/v2/ocr/jobs

SANDBOX_PROVISIONER_BACKEND=docker
SANDBOX_DOCKER_NETWORK=yuxi-split-app-network
SANDBOX_DOCKER_THREADS_HOST_PATH=
SANDBOX_DOCKER_SANDBOX_PREFIX=yuxi-split-sandbox
SANDBOX_DOCKER_SANDBOX_HOST=host.docker.internal
SANDBOX_VIRTUAL_PATH_PREFIX=/home/gem/user-data
SANDBOX_EXEC_TIMEOUT_SECONDS=180
SANDBOX_MAX_OUTPUT_BYTES=262144

# Add the infrastructure server IP/domain here when an HTTP proxy is configured.
NO_PROXY=localhost,127.0.0.1,host.docker.internal,sandbox-provisioner,api.siliconflow.cn
