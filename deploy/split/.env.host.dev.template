# Copy this file to the repository root as .env, then fill every required value.
# API, Worker, Web and Sandbox Provisioner run as host processes in this mode.

YUXI_ENV=development
LITE_MODE=false
JWT_SECRET_KEY=
YUXI_INSTANCE_ID=
YUXI_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Remote infrastructure. Never use Docker service names or localhost here.
# Percent-encode special characters in URL passwords.
POSTGRES_URL=
REDIS_URL=

NEO4J_URI=
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=

MILVUS_URI=
MILVUS_DB=yuxi
MILVUS_TOKEN=

MINIO_URI=
MINIO_PUBLIC_URI=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=

# Model and external tool credentials.
SILICONFLOW_API_KEY=
TAVILY_API_KEY=
# YUXI_SUPER_ADMIN_NAME=
# YUXI_SUPER_ADMIN_PASSWORD=

# Optional remote document parser services.
MINERU_API_URI=
PADDLEX_URI=
PADDLEOCR_API_TOKEN=
PADDLEOCR_API_URL=https://paddleocr.aistudio-app.com/api/v2/ocr/jobs

# Host-process ports used by scripts/split-deploy/Start-HostService.ps1.
HOST_DEV_API_HOST=127.0.0.1
HOST_DEV_API_PORT=5050
HOST_DEV_WEB_HOST=127.0.0.1
HOST_DEV_WEB_PORT=5173
HOST_DEV_SANDBOX_HOST=127.0.0.1
HOST_DEV_SANDBOX_PORT=8002
VITE_API_URL=http://127.0.0.1:5050

# API/Worker access the provisioner on the host.
SANDBOX_PROVIDER=provisioner
SANDBOX_PROVISIONER_URL=http://127.0.0.1:8002
SANDBOX_VIRTUAL_PATH_PREFIX=/home/gem/user-data
SANDBOX_EXEC_TIMEOUT_SECONDS=180
SANDBOX_MAX_OUTPUT_BYTES=262144

# Provisioner runs on the host. The docker backend still creates sandbox containers.
PROVISIONER_BACKEND=docker
SANDBOX_IMAGE=enterprise-public-cn-beijing.cr.volces.com/vefaas-public/all-in-one-sandbox:latest
SANDBOX_CONTAINER_PORT=8080
DOCKER_THREADS_HOST_PATH=
DOCKER_SANDBOX_PREFIX=yuxi-host-sandbox
DOCKER_SANDBOX_HOST=127.0.0.1
SANDBOX_HEALTH_TIMEOUT_SECONDS=300
SANDBOX_IDLE_TIMEOUT_SECONDS=120
SANDBOX_IDLE_CHECK_INTERVAL_SECONDS=10

# Add the infrastructure server IP/domain when an HTTP proxy is configured.
NO_PROXY=localhost,127.0.0.1,api.siliconflow.cn
