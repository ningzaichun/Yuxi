# Copy this file to deploy/split/.env.infra and replace every empty secret.
# Keep 127.0.0.1 when using SSH tunnels. For private-network/VPN access, use
# the server's private IPv4 address. Do not bind these ports to a public IP.
INFRA_BIND_HOST=127.0.0.1
TZ=Asia/Shanghai

POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=yuxi
POSTGRES_PORT=5432

REDIS_PASSWORD=
REDIS_PORT=6379

# These credentials are shared by the Yuxi application and Milvus.
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

MILVUS_PORT=19530
MILVUS_HEALTH_PORT=9091
MILVUS_LOG_LEVEL=error

# Neo4j requires a password of at least 8 characters.
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
